# ──────────────────────────────────────────────────────────────────────────
# Exchange selection
# Choose which exchange the bot trades on: "binance" or "kraken".
# Both integrations are compiled in; flip this value to switch (e.g. back to
# binance later). Only the selected exchange's API credentials are required.
# ──────────────────────────────────────────────────────────────────────────
EXCHANGE=kraken

# Binance API Configuration (used when EXCHANGE=binance)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here

# Kraken API Configuration (used when EXCHANGE=kraken)
# The secret is the base64 "Private Key" shown when you create the API key.
KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_SECRET_KEY=your_kraken_private_key_here

# Trading Configuration
DCA_AMOUNT_EUR=62.5
MIN_BALANCE_USDC=50.0
SCHEDULE_CRON=0 0 12 * * *

# Notion Integration (Optional)
NOTION_TOKEN=your_notion_integration_token_here
NOTION_DATABASE_ID=your_notion_database_id_here
COLD_WALLET_ADDRESS=0xa416610975634033374EEdAE26D0FCa7A7360b70

# Withdrawal Configuration (Optional)
WITHDRAWAL_ENABLED=false
# On Binance: WITHDRAWAL_WALLET_ADDRESS is the on-chain destination address.
# On Kraken:  it is the name of a pre-registered withdrawal key (whitelisted
#             address configured in the Kraken UI under Funding → Withdraw).
WITHDRAWAL_WALLET_ADDRESS=my_cold_wallet_key
# WITHDRAWAL_NETWORK: used by Binance to pick the chain. On Kraken the network is
# implied by the withdrawal key, so this is informational only.
WITHDRAWAL_NETWORK=ARBITRUM
WITHDRAWAL_MIN_ETH_THRESHOLD=0.0003
# WITHDRAWAL_AMOUNT=0.5  # Optional: if not set, withdraws all available ETH

# MongoDB Configuration (if using)
MONGODB_URL=

# ──────────────────────────────────────────────────────────────────────────
# BTC DCA Workflow (Optional) — runs alongside ETH in the same process.
# Set BTC_DCA_ENABLED=true to activate. All BTC_* vars below are optional and
# fall back to the defaults shown. BTC uses its own Mongo collection and its
# own Notion database so its stats stay separate from ETH.
# ──────────────────────────────────────────────────────────────────────────
BTC_DCA_ENABLED=false
BTC_DCA_AMOUNT_EUR=62.5
BTC_MIN_BALANCE_USDC=50.0
BTC_SCHEDULE_CRON=0 30 5 * * MON
# BTC_TIMEZONE=Europe/Berlin   # defaults to the global TIMEZONE if unset
# BTC_MONGO_COLLECTION=btc_purchases

# BTC Notion (own database; token defaults to NOTION_TOKEN if unset)
# BTC_NOTION_TOKEN=
# BTC_NOTION_DATABASE_ID=
# BTC_COLD_WALLET_ADDRESS=bc1q...

# BTC Withdrawal (Optional)
# As above: a raw address on Binance, or a Kraken withdrawal key name on Kraken.
BTC_WITHDRAWAL_ENABLED=false
# BTC_WITHDRAWAL_WALLET_ADDRESS=my_btc_cold_wallet_key
BTC_WITHDRAWAL_NETWORK=BTC
BTC_WITHDRAWAL_MIN_THRESHOLD=0.0001
# BTC_WITHDRAWAL_AMOUNT=0.01  # Optional: if not set, withdraws all available BTC
# ──────────────────────────────────────────────────────────────────────────
# Limit-Order Sleeve (Optional) — rests post-only bids at volume-profile levels
# below spot, funded by a fixed USDC war chest that drains as dips fill (never
# auto-replenished). Fully isolated from DCA: own budget, own Mongo collection,
# and tagged as "Limit Sleeve Fill" in the shared Notion monthly page so DCA
# stats stay pure. Kraken only (reuses its post-only order path).
# Set LIMIT_SLEEVE_ENABLED=true to activate; all vars below fall back to the
# defaults shown.
# ──────────────────────────────────────────────────────────────────────────
LIMIT_SLEEVE_ENABLED=false
# LIMIT_SLEEVE_SYMBOL=ETHUSDC
LIMIT_SLEEVE_WAR_CHEST_USDC=500.0
# 7-field cron (with seconds). Default: every 6 hours.
LIMIT_SLEEVE_REFRESH_CRON=0 0 */6 * * *
# LIMIT_SLEEVE_TIMEZONE=Europe/Berlin   # defaults to the global TIMEZONE if unset
# OHLC candle interval in minutes; also sets the lookback (Kraken caps at ~720
# candles, so 60 ≈ 30 days).
LIMIT_SLEEVE_INTERVAL_MINUTES=60
# LIMIT_SLEEVE_MONGO_COLLECTION=limit_sleeve_fills

# Volume-profile tunables (see src/levels.rs)
# Price width of one bucket, in quote currency (per asset).
VP_BUCKET_SIZE_ETH=5.0
# A node counts as "high volume" at >= this fraction of the VPOC bucket's volume.
VP_HVN_THRESHOLD_RATIO=0.7
# Max number of bids in the ladder.
VP_LADDER_STEPS=4
# Require HVNs to be strict local maxima (distinct levels, not adjacent blocks).
VP_REQUIRE_LOCAL_MAXIMA=true
