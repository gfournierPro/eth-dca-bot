# Example production environment file
# Copy this to .env.prod and fill in your actual values

# Binance API Configuration
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here
BINANCE_BASE_URL=https://api.binance.com

# Trading Configuration
DCA_AMOUNT_EUR=50
MIN_USDC_BALANCE=10
EUR_TO_USDC_RATE=1.1

# Withdrawal Configuration (IMPORTANT: Use your actual ETH address)
WITHDRAWAL_ADDRESS=0xYourEthereumAddressHere
WITHDRAWAL_THRESHOLD=0.1
WITHDRAWAL_START_DAY=25
WITHDRAWAL_END_DAY=5

# Scheduling (Default: Every Monday at 9 AM)
CRON_EXPRESSION=0 9 * * MON
TIMEZONE=Europe/Berlin

# MongoDB Password (Generate a strong password)
MONGO_PASSWORD=your_secure_mongodb_password_here

# Notion Integration (Optional - leave empty if not using)
NOTION_TOKEN=
NOTION_DATABASE_ID=

# BTC DCA Workflow (Optional) — runs alongside ETH. Set BTC_DCA_ENABLED=true.
BTC_DCA_ENABLED=false
BTC_DCA_AMOUNT_EUR=50
BTC_SCHEDULE_CRON=0 9 * * MON
# BTC_NOTION_DATABASE_ID=
# BTC_COLD_WALLET_ADDRESS=bc1q...
BTC_WITHDRAWAL_ENABLED=false
BTC_WITHDRAWAL_NETWORK=BTC
BTC_WITHDRAWAL_MIN_THRESHOLD=0.0001

# Logging Level
RUST_LOG=info
