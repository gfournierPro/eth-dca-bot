# Example production environment file
# Copy this to .env.prod and fill in your actual values

# Exchange selection: "binance" or "kraken"
EXCHANGE=kraken

# Binance API Configuration (used when EXCHANGE=binance)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here
BINANCE_BASE_URL=https://api.binance.com

# Kraken API Configuration (used when EXCHANGE=kraken)
KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_SECRET_KEY=your_kraken_private_key_here
KRAKEN_BASE_URL=https://api.kraken.com

# Trading Configuration
DCA_AMOUNT_EUR=50
MIN_BALANCE_USDC=10

# Withdrawal Configuration (IMPORTANT: Use your actual ETH address)
WITHDRAWAL_ENABLED=false
WITHDRAWAL_WALLET_ADDRESS=0xYourEthereumAddressHere
WITHDRAWAL_NETWORK=ARBITRUM
WITHDRAWAL_MIN_ETH_THRESHOLD=0.1

# Scheduling (Default: Every Monday at 9 AM)
SCHEDULE_CRON=0 9 * * MON
TIMEZONE=Europe/Berlin

# MongoDB Password (Generate a strong password)
MONGO_PASSWORD=your_secure_mongodb_password_here

# Notion Integration (Optional - leave empty if not using)
NOTION_TOKEN=
NOTION_DATABASE_ID=
COLD_WALLET_ADDRESS=

# BTC DCA Workflow — runs alongside ETH by default. Set BTC_DCA_ENABLED=false to opt out.
BTC_DCA_ENABLED=true
BTC_DCA_AMOUNT_EUR=50
BTC_SCHEDULE_CRON=0 9 * * MON
# BTC_NOTION_DATABASE_ID=
# BTC_COLD_WALLET_ADDRESS=bc1q...
BTC_WITHDRAWAL_ENABLED=false
BTC_WITHDRAWAL_NETWORK=BTC
BTC_WITHDRAWAL_MIN_THRESHOLD=0.0001

# Logging Level
RUST_LOG=info
